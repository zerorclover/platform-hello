{
  "jobs": {
    "backend-test": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "actions/setup-node@v4" },
        { "run": "npm test" }
      ]
    },
    "secret-scan": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "gitleaks/gitleaks-action@v2" }
      ]
    },
    "terraform-validate": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "hashicorp/setup-terraform@v3" },
        { "run": "terraform validate" }
      ]
    },
    "deploy-staging": {
      "environment": "staging",
      "steps": [
        { "run": "terraform plan/apply -var environment=staging" }
      ]
    },
    "deploy-production": {
      "environment": "production",
      "steps": [
        { "run": "terraform plan/apply -var environment=production" }
      ]
    }
  }
}
