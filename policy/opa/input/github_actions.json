{
  "jobs": {
    "backend-test": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "actions/setup-node@v4" },
        { "run": "npm test" }
      ]
    },
    "secret-scan": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "gitleaks/gitleaks-action@v2" }
      ]
    },
    "terraform-validate": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "hashicorp/setup-terraform@v3" },
        { "run": "terraform validate" }
      ]
    },
    "prepare-environment": {
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "hashicorp/setup-terraform@v3" },
        { "uses": "aws-actions/configure-aws-credentials@v4" },
        { "run": "terraform apply -target=module.platform.module.container_platform.aws_ecr_repository.backend -target=module.platform.module.container_platform.aws_ecr_repository.frontend" }
      ]
    },
    "package-images": {
      "needs": ["prepare-environment"],
      "steps": [
        { "uses": "actions/checkout@v4" },
        { "uses": "docker/setup-buildx-action@v3" },
        { "uses": "aws-actions/configure-aws-credentials@v4" },
        { "uses": "aws-actions/amazon-ecr-login@v2" },
        { "uses": "docker/build-push-action@v6", "with": { "push": true } }
      ]
    },
    "deploy": {
      "environment": "${{ inputs.environment }}",
      "needs": ["package-images"],
      "steps": [
        { "run": "terraform plan/apply with TF_VAR_environment from workflow input" }
      ]
    }
  }
}
